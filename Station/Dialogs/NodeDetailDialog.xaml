<ContentDialog
    x:Class="Station.Dialogs.NodeDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Station.Dialogs"
    RequestedTheme="Dark"
    Background="{StaticResource DkSurfaceBrush}"
    BorderBrush="{StaticResource DkBorderBrush}"
    CornerRadius="12"
    Padding="0">

    <ContentDialog.Resources>
        <Style x:Key="DangerBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F0E0E"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#2D1010"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#EF4444"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#450E0E"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource DkBorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,11"/>
        </Style>
    </ContentDialog.Resources>

    <!-- Root: fixed height so dialog doesn't jump with tab content -->
    <Grid MinWidth="920" MaxWidth="960" Height="800">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Tabs -->
            <RowDefinition Height="*"/>     <!-- Content (scrollable) -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
        <Border Grid.Row="0" Padding="20,16"
                Background="{StaticResource DkSurfaceBrush}"
                BorderBrush="{StaticResource DkBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Node icon -->
                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10"
                        Background="{StaticResource DkBlueBgBrush}"
                        BorderBrush="{StaticResource DkBlueBorderBrush}" BorderThickness="1"
                        Margin="0,0,14,0">
                    <FontIcon Glyph="&#xE968;" FontSize="20"
                              Foreground="{StaticResource DkBlueBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title + subtitle -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="DialogNodeName"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource DkTextPrimaryBrush}"/>
                        <Border x:Name="DialogStatusBadge"
                                CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                            <TextBlock x:Name="DialogStatusText"
                                       FontSize="10" FontWeight="Bold" CharacterSpacing="30"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DialogNodeLocation"
                               FontSize="12" Foreground="{StaticResource DkTextMutedBrush}"/>
                </StackPanel>

                <!-- Close -->
                <Button Grid.Column="2" Style="{StaticResource DkIconButtonStyle}"
                        Click="CloseButton_Click">
                    <FontIcon Glyph="&#xE711;" FontSize="14"
                              Foreground="{StaticResource DkTextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════ TABS ═══════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource DkBgBrush}"
                BorderBrush="{StaticResource DkBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,0">
            <StackPanel Orientation="Horizontal" Spacing="0">
                <Border x:Name="Tab1Border" Padding="0,0,28,0"
                        BorderBrush="{StaticResource DkBlueBrush}" BorderThickness="0,0,0,2"
                        Tapped="Tab_Tapped" Tag="0" IsHitTestVisible="True">
                    <TextBlock x:Name="Tab1Text" Text="Thông tin chung"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource DkBlueBrush}"
                               Padding="0,14"/>
                </Border>
                <Border x:Name="Tab2Border" Padding="0,0,28,0"
                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                        Tapped="Tab_Tapped" Tag="1" IsHitTestVisible="True">
                    <TextBlock x:Name="Tab2Text" Text="Cấu hình &amp; Cài đặt"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource DkTextMutedBrush}"
                               Padding="0,14"/>
                </Border>
                <Border x:Name="Tab3Border" Padding="0"
                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                        Tapped="Tab_Tapped" Tag="2" IsHitTestVisible="True">
                    <TextBlock x:Name="Tab3Text" Text="Dữ liệu trực tiếp"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource DkTextMutedBrush}"
                               Padding="0,14"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════ CONTENT ═══════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20,16,20,20">
            <Grid>

                <!-- ── TAB 1: Thông tin chung ── -->
                <StackPanel x:Name="Tab1Panel" Spacing="14">

                    <!-- Quick stats (3 cards) -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mức pin -->
                        <Border Grid.Column="0" Padding="16"
                                Background="{StaticResource DkBgBrush}"
                                BorderBrush="{StaticResource DkBorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Mức pin" FontSize="12"
                                               Foreground="{StaticResource DkTextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE83E;" FontSize="15"
                                              Foreground="{StaticResource DkGreenBrush}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                    <TextBlock Text="85%" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}"/>
                                    <TextBlock Text="+1.2% / ngày" FontSize="11"
                                               Foreground="{StaticResource DkGreenBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Tín hiệu -->
                        <Border Grid.Column="1" Padding="16"
                                Background="{StaticResource DkBgBrush}"
                                BorderBrush="{StaticResource DkBorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Cường độ tín hiệu" FontSize="12"
                                               Foreground="{StaticResource DkTextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE701;" FontSize="15"
                                              Foreground="{StaticResource DkBlueBrush}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                    <TextBlock Text="Mạnh" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}"/>
                                    <TextBlock Text="-65 dBm" FontSize="11"
                                               Foreground="{StaticResource DkTextMutedBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Uptime -->
                        <Border Grid.Column="2" Padding="16"
                                Background="{StaticResource DkBgBrush}"
                                BorderBrush="{StaticResource DkBorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Thời gian hoạt động" FontSize="12"
                                               Foreground="{StaticResource DkTextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE121;" FontSize="15"
                                              Foreground="{StaticResource DkTextDimBrush}"
                                              HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                    <TextBlock Text="42 ngày" FontSize="22" FontWeight="Bold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}"/>
                                    <TextBlock Text="liên tục" FontSize="11"
                                               Foreground="{StaticResource DkTextMutedBrush}"
                                               VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Detail list + Location (2 columns) -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Detail list -->
                        <Border Grid.Column="0" Padding="16"
                                Background="{StaticResource DkBgBrush}"
                                BorderBrush="{StaticResource DkBorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="THÔNG TIN CHI TIẾT" FontSize="10" FontWeight="Bold"
                                           CharacterSpacing="60"
                                           Foreground="{StaticResource DkTextDimBrush}"
                                           Margin="0,0,0,4"/>

                                <Border Style="{StaticResource DetailRowStyle}">
                                    <Grid>
                                        <TextBlock Text="Trạng thái" FontSize="13"
                                                   Foreground="{StaticResource DkTextMutedBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    HorizontalAlignment="Right">
                                            <Ellipse x:Name="DetailStatusDot"
                                                     Width="7" Height="7" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="DetailStatusText"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource DetailRowStyle}">
                                    <Grid>
                                        <TextBlock Text="Tuyến" FontSize="13"
                                                   Foreground="{StaticResource DkTextMutedBrush}"/>
                                        <TextBlock x:Name="DetailLineText"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DkTextPrimaryBrush}"
                                                   HorizontalAlignment="Right"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource DetailRowStyle}">
                                    <Grid>
                                        <TextBlock Text="Ngày lắp đặt" FontSize="13"
                                                   Foreground="{StaticResource DkTextMutedBrush}"/>
                                        <TextBlock Text="15/03/2023" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DkTextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource DetailRowStyle}">
                                    <Grid>
                                        <TextBlock Text="Số cảm biến" FontSize="13"
                                                   Foreground="{StaticResource DkTextMutedBrush}"/>
                                        <TextBlock x:Name="DetailSensorCountText"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DkTextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Padding="0,11">
                                    <Grid>
                                        <TextBlock Text="Nhân viên bảo trì" FontSize="13"
                                                   Foreground="{StaticResource DkTextMutedBrush}"/>
                                        <TextBlock Text="Nguyễn Văn A" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DkTextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Location placeholder -->
                        <Border Grid.Column="1" Padding="16"
                                Background="{StaticResource DkBgBrush}"
                                BorderBrush="{StaticResource DkBorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <StackPanel Spacing="12">
                                <TextBlock Text="VỊ TRÍ TRÊN BẢN ĐỒ" FontSize="10" FontWeight="Bold"
                                           CharacterSpacing="60"
                                           Foreground="{StaticResource DkTextDimBrush}"/>
                                <Border Background="{StaticResource DkSurfaceBrush}"
                                        BorderBrush="{StaticResource DkBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" MinHeight="172">
                                    <StackPanel VerticalAlignment="Center"
                                                HorizontalAlignment="Center" Spacing="8">
                                        <FontIcon Glyph="&#xE707;" FontSize="36"
                                                  Foreground="{StaticResource DkBlueBrush}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MapLocationText"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource DkTextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Bản đồ đang phát triển"
                                                   FontSize="11"
                                                   Foreground="{StaticResource DkTextDimBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Sensor readings grid -->
                    <Border Padding="16"
                            Background="{StaticResource DkBgBrush}"
                            BorderBrush="{StaticResource DkBorderBrush}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9CA;" FontSize="13"
                                          Foreground="{StaticResource DkTextDimBrush}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="CẢM BIẾN TRỰC TIẾP" FontSize="10" FontWeight="Bold"
                                           CharacterSpacing="60"
                                           Foreground="{StaticResource DkTextDimBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ItemsRepeater x:Name="SensorReadingsRepeater">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout MaximumRowsOrColumns="4"
                                                       MinItemWidth="80"
                                                       ItemsStretch="Fill"
                                                       MinColumnSpacing="8"
                                                       MinRowSpacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DkSensorCardStyle}">
                                            <StackPanel Spacing="5">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="{Binding TypeIcon}" FontSize="10"
                                                              Foreground="{StaticResource DkTextDimBrush}"
                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding SensorTypeDisplay}"
                                                               FontSize="9" FontWeight="Bold"
                                                               CharacterSpacing="40"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{StaticResource DkTextDimBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding CurrentValue}"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{Binding SensorStatusColor}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Ellipse Width="5" Height="5"
                                                             Fill="{Binding SensorStatusColor}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Unit}"
                                                               FontSize="10"
                                                               Foreground="{StaticResource DkTextDimBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── TAB 2: Cấu hình & Cài đặt ── -->
                <Border x:Name="Tab2Panel" Visibility="Collapsed" Padding="40"
                        Background="{StaticResource DkBgBrush}"
                        BorderBrush="{StaticResource DkBorderBrush}"
                        BorderThickness="1" CornerRadius="10"
                        MinHeight="400">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE713;" FontSize="44"
                                  Foreground="{StaticResource DkTextDimBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Cấu hình đang phát triển"
                                   FontSize="15" Foreground="{StaticResource DkTextMutedBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Tính năng này sẽ có trong phiên bản tiếp theo"
                                   FontSize="12" Foreground="{StaticResource DkTextDimBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- ── TAB 3: Dữ liệu trực tiếp ── -->
                <Grid x:Name="Tab3Panel" Visibility="Collapsed" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Mini chart card -->
                    <Border Grid.Column="0" Padding="16"
                            Background="{StaticResource DkBgBrush}"
                            BorderBrush="{StaticResource DkBorderBrush}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel Spacing="14">
                            <Grid>
                                <TextBlock Text="Lưu lượng nước (Radar)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource DkTextSecondaryBrush}"/>
                                <TextBlock Text="Cập nhật 10 giây trước"
                                           FontSize="11" Foreground="{StaticResource DkTextDimBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Mock bar chart -->
                            <Border Background="{StaticResource DkSurfaceBrush}"
                                    BorderBrush="{StaticResource DkBorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Height="140" Padding="12,8">
                                <StackPanel Orientation="Horizontal" Spacing="5"
                                            VerticalAlignment="Bottom">
                                    <Border Background="#1D4ED8" Opacity="0.5" Width="18" Height="56" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.6" Width="18" Height="77" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.8" Width="18" Height="98" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.6" Width="18" Height="84" CornerRadius="3,3,0,0"/>
                                    <Border Background="#3B82F6" Opacity="0.9" Width="18" Height="119" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.6" Width="18" Height="63" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.4" Width="18" Height="42" CornerRadius="3,3,0,0"/>
                                    <Border Background="#3B82F6" Opacity="0.95" Width="18" Height="126" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.5" Width="18" Height="70" CornerRadius="3,3,0,0"/>
                                    <Border Background="#1D4ED8" Opacity="0.4" Width="18" Height="49" CornerRadius="3,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Min" FontSize="10" Foreground="{StaticResource DkTextDimBrush}"/>
                                    <TextBlock Text="12%" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Trung bình" FontSize="10" Foreground="{StaticResource DkTextDimBrush}"/>
                                    <TextBlock Text="45%" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Max" FontSize="10" Foreground="{StaticResource DkTextDimBrush}"/>
                                    <TextBlock Text="89%" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Camera live feed -->
                    <Border Grid.Column="1" Padding="16"
                            Background="{StaticResource DkBgBrush}"
                            BorderBrush="{StaticResource DkBorderBrush}"
                            BorderThickness="1" CornerRadius="10">
                        <StackPanel Spacing="14">
                            <Grid>
                                <TextBlock Text="Camera trực tiếp (Hệ thống cống)"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource DkTextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="5"
                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Ellipse Width="7" Height="7" Fill="#EF4444"/>
                                    <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold"
                                               Foreground="#EF4444" CharacterSpacing="40"/>
                                </StackPanel>
                            </Grid>

                            <!-- Feed placeholder -->
                            <Border Background="#0A0A0A"
                                    BorderBrush="{StaticResource DkBorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Height="140">
                                <Grid>
                                    <FontIcon Glyph="&#xE890;" FontSize="40"
                                              Foreground="#FFFFFF30"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                Margin="10,0,0,10" Spacing="3">
                                        <Border Background="#00000066" CornerRadius="3" Padding="6,2">
                                            <TextBlock x:Name="CamTimestampText"
                                                       FontSize="10" Foreground="#FFFFFFB0"/>
                                        </Border>
                                        <Border Background="#00000066" CornerRadius="3" Padding="6,2">
                                            <TextBlock x:Name="CamIdText"
                                                       FontSize="10" Foreground="#FFFFFFB0"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="Camera ID" FontSize="12" Foreground="{StaticResource DkTextMutedBrush}"/>
                                    <TextBlock x:Name="CamIdDetail" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource DkTextPrimaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Trạng thái" FontSize="12" Foreground="{StaticResource DkTextMutedBrush}"/>
                                    <TextBlock x:Name="CamStatusDetail" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource DkGreenBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════════════ FOOTER ═══════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource DkSurfaceBrush}"
                BorderBrush="{StaticResource DkBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: secondary actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource DkSecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE81C;" FontSize="13"
                                      Foreground="{StaticResource DkTextSecondaryBrush}"/>
                            <TextBlock Text="Lịch sử log" FontSize="13"
                                       Foreground="{StaticResource DkTextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerBtnStyle}"
                            Click="RestartButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="#EF4444"/>
                            <TextBlock Text="Khởi động lại" FontSize="13" Foreground="#EF4444"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Right: close / save -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource DkSecondaryButtonStyle}"
                            Click="CloseButton_Click">
                        <TextBlock Text="Đóng" FontSize="13"
                                   Foreground="{StaticResource DkTextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource DkPrimaryButtonStyle}">
                        <TextBlock Text="Lưu thay đổi" FontSize="13" Foreground="White"/>
