<Page
    x:Class="Station.Views.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Station.ViewModels"
    Background="{StaticResource DkBgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Filter bar -->
            <RowDefinition Height="*"/>      <!-- Cards grid -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                          -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource DkHeaderBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + live badge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="14" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Quản lý Thiết bị Cống ngầm"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource DkTextPrimaryBrush}"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource DkTextMutedBrush}"
                                   Margin="0,2,0,0">
                            <Run Text="{x:Bind ViewModel.TotalDevices, Mode=OneWay}"/>
                            <Run Text="thiết bị •"/>
                            <Run Text="{x:Bind ViewModel.OnlineDevices, Mode=OneWay}" Foreground="#22C55E"/>
                            <Run Text="hoạt động •" Foreground="#22C55E"/>
                            <Run Text="{x:Bind ViewModel.OfflineDevices, Mode=OneWay}" Foreground="#64748B"/>
                            <Run Text="offline •" Foreground="#64748B"/>
                            <Run Text="{x:Bind ViewModel.FaultDevices, Mode=OneWay}" Foreground="#EF4444"/>
                            <Run Text="lỗi" Foreground="#EF4444"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Right: search + add button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Spacing="10" VerticalAlignment="Center">
                    <Grid>
                        <TextBox Style="{StaticResource DkSearchBoxStyle}"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Tìm kiếm ID, vị trí..."
                                 MinWidth="260"/>
                        <FontIcon Glyph="&#xE721;" FontSize="14"
                                  Foreground="{StaticResource DkTextMutedBrush}"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Margin="12,0,0,0" IsHitTestVisible="False"/>
                    </Grid>
                    <Button Style="{StaticResource DkPrimaryButtonStyle}"
                            Click="AddDeviceButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="White"/>
                            <TextBlock Text="Thêm thiết bị" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- FILTER BAR                                                       -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource DkSurfaceBrush}"
                BorderBrush="{StaticResource DkBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,10,24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Line filter -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            Spacing="8" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Tuyến:" Style="{StaticResource DkLabelStyle}"
                               VerticalAlignment="Center"/>
                    <ComboBox Style="{StaticResource DkComboBoxStyle}"
                              ItemsSource="{x:Bind ViewModel.LineFilters}"
                              SelectedItem="{x:Bind ViewModel.SelectedLine, Mode=TwoWay}"
                              MinWidth="160"/>
                </StackPanel>

                <!-- Status pill filters -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            Spacing="6" VerticalAlignment="Center">
                    <Border x:Name="FilterAllBorder" Tag="Tất cả trạng thái"
                            Style="{StaticResource FilterPillActiveStyle}"
                            Tapped="StatusFilter_Tapped">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource DkBlueBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FilterAllText" Text="Tất cả"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource DkBlueBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FilterOnlineBorder" Tag="Hoạt động"
                            Style="{StaticResource FilterPillStyle}"
                            Tapped="StatusFilter_Tapped">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource DkGreenBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FilterOnlineText" Text="Hoạt động"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource DkTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FilterFaultBorder" Tag="Lỗi"
                            Style="{StaticResource FilterPillStyle}"
                            Tapped="StatusFilter_Tapped">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource DkYellowBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FilterFaultText" Text="Bảo trì"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource DkTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FilterOfflineBorder" Tag="Ngoại tuyến"
                            Style="{StaticResource FilterPillStyle}"
                            Tapped="StatusFilter_Tapped">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource DkGrayBrush}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FilterOfflineText" Text="Offline"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource DkTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Export button (right) -->
                <Button Grid.Column="3" Style="{StaticResource DkSecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="13"
                                  Foreground="{StaticResource DkTextSecondaryBrush}"/>
                        <TextBlock Text="Xuất báo cáo" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- DEVICE CARDS GRID                                               -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Padding="20,16,20,20">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredNodes, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MaximumRowsOrColumns="3"
                                       MinItemWidth="300"
                                       ItemsStretch="Fill"
                                       MinColumnSpacing="14"
                                       MinRowSpacing="14"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>

                        <!-- ── NODE CARD ── -->
                        <Border Style="{StaticResource DkCardStyle}"
                                Tag="{Binding}"
                                Tapped="DeviceCard_Tapped"
                                PointerEntered="DeviceCard_PointerEntered"
                                PointerExited="DeviceCard_PointerExited">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Card Header -->
                                <Border Grid.Row="0" Padding="14,12"
                                        Background="{Binding StatusBackgroundColor}"
                                        BorderBrush="{StaticResource DkBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="12,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Node icon -->
                                        <Border Grid.Column="0"
                                                Width="46" Height="46" CornerRadius="10" Margin="0,0,12,0"
                                                Background="{StaticResource DkBgBrush}"
                                                BorderBrush="{Binding StatusColor}" BorderThickness="1">
                                            <FontIcon Glyph="&#xE968;" FontSize="20"
                                                      Foreground="{Binding StatusColor}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Node name + location -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding NodeName}"
                                                           FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource DkTextPrimaryBrush}"/>
                                                <Border Background="{Binding StatusBackgroundColor}"
                                                        BorderBrush="{Binding StatusColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="4" Padding="7,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               FontSize="10" FontWeight="Bold"
                                                               CharacterSpacing="30"
                                                               Foreground="{Binding StatusColor}"/>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="&#xE707;" FontSize="10"
                                                          Foreground="{StaticResource DkTextDimBrush}"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Location}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource DkTextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    Spacing="0" VerticalAlignment="Top" Margin="0,-2,0,0">
                                            <Button Style="{StaticResource DkIconButtonStyle}"
                                                    ToolTipService.ToolTip="Cấu hình"
                                                    Tag="{Binding}"
                                                    Click="ConfigButton_Click">
                                                <FontIcon Glyph="&#xE713;" FontSize="14"
                                                          Foreground="{StaticResource DkTextDimBrush}"/>
                                            </Button>
                                            <Button Style="{StaticResource DkIconButtonStyle}"
                                                    ToolTipService.ToolTip="Khởi động lại"
                                                    Tag="{Binding}"
                                                    Click="RestartButton_Click">
                                                <FontIcon Glyph="&#xE72C;" FontSize="14"
                                                          Foreground="{StaticResource DkTextDimBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Sensor readings grid -->
                                <Border Grid.Row="1" Padding="12"
                                        Style="{StaticResource DkInsetStyle}">
                                    <ItemsRepeater ItemsSource="{Binding Sensors}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MaximumRowsOrColumns="4"
                                                               MinItemWidth="80"
                                                               ItemsStretch="Fill"
                                                               MinColumnSpacing="8"
                                                               MinRowSpacing="8"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource DkSensorCardStyle}">
                                                    <StackPanel Spacing="5">
                                                        <!-- Label row -->
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="{Binding TypeIcon}" FontSize="10"
                                                                      Foreground="{StaticResource DkTextDimBrush}"
                                                                      VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding SensorTypeDisplay}"
                                                                       FontSize="9" FontWeight="Bold"
                                                                       CharacterSpacing="40"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{StaticResource DkTextDimBrush}"/>
                                                        </StackPanel>
                                                        <!-- Value -->
                                                        <TextBlock Text="{Binding CurrentValue}"
                                                                   FontSize="16" FontWeight="Bold"
                                                                   Foreground="{Binding SensorStatusColor}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <!-- Unit + dot -->
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <Ellipse Width="5" Height="5"
                                                                     Fill="{Binding SensorStatusColor}"
                                                                     VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Unit}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource DkTextDimBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Border>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
