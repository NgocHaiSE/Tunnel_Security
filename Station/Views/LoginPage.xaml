<Page
    x:Class="Station.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Background="#111621">

    <Grid>

        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111621" Offset="0"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Center login card -->
        <Border
            Width="420"
            Padding="32"
            CornerRadius="14"
            Background="#1C222D"
            BorderBrush="#2D3545"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <StackPanel Spacing="18">

                <!-- Header -->
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="10">

                        <Border
                            Width="40"
                            Height="40"
                            Background="#144BB8"
                            CornerRadius="8">

                            <FontIcon
                                Glyph="&#xE946;"
                                Foreground="White"
                                FontSize="18"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"/>
                        </Border>

                        <StackPanel>
                            <TextBlock
                                Text="Tunnel Security"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="#F1F5F9"/>

                            <TextBlock
                                Text="Hệ thống giám sát đường hầm"
                                FontSize="12"
                                Foreground="#64748B"/>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#2D3545"/>

                <!-- Username -->
                <StackPanel Spacing="6">
                    <TextBlock
        Text="TÊN ĐĂNG NHẬP"
        FontSize="11"
        FontWeight="Bold"
        Foreground="#64748B"
        CharacterSpacing="60"/>

                    <Border
        Background="#111621"
        BorderBrush="#2D3545"
        BorderThickness="1"
        CornerRadius="8">

                        <TextBox
            x:Name="UsernameBox"
            PlaceholderText="Nhập username..."
            Background="Transparent"
            Foreground="#E2E8F0"
            Padding="10"/>
                    </Border>
                </StackPanel>

                <!-- Password -->
                <StackPanel Spacing="6">
                    <TextBlock
        Text="MẬT KHẨU"
        FontSize="11"
        FontWeight="Bold"
        Foreground="#64748B"
        CharacterSpacing="60"/>

                    <Border
        Background="#111621"
        BorderBrush="#2D3545"
        BorderThickness="1"
        CornerRadius="8">

                        <PasswordBox
            x:Name="PasswordBox"
            Background="Transparent"
            Foreground="#E2E8F0"
            Padding="10"/>
                    </Border>
                </StackPanel>

                <!-- Error text -->
                <TextBlock
                    x:Name="ErrorText"
                    Foreground="#EF4444"
                    FontSize="12"
                    Visibility="Collapsed"/>

                <!-- Login button -->
                <Button
                    x:Name="LoginButton"
                    Click="LoginButton_Click"
                    Background="#144BB8"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="12"
                    CornerRadius="8"
                    FontWeight="SemiBold">

                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center">

                        <FontIcon Glyph="&#xE72E;" FontSize="14"/>
                        <TextBlock Text="Đăng nhập"/>

                    </StackPanel>

                </Button>

                <!-- Footer -->
                <TextBlock
                    Text="Tunnel Monitoring System"
                    FontSize="11"
                    Foreground="#475569"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,0"/>

            </StackPanel>
        </Border>

    </Grid>
</Page>